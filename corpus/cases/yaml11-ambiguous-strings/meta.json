{
  "summary": "Quoted strings can stay valid while covering YAML 1.1-ambiguous spellings",
  "tags": [
    "string",
    "y11safety",
    "strict",
    "emit"
  ],
  "spec_refs": [
    "optional.strict-mode",
    "optional.yaml11-safety",
    "serialization-defaults"
  ],
  "emit_profiles": {
    "default": {
      "mode": "default",
      "expect_output": "expected_emit_default.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    },
    "y11safety": {
      "mode": "y11safety",
      "expect_output": "expected_emit_y11safety.yaml"
    },
    "roundtrip": {
      "mode": "default",
      "options": {
        "roundtrip": true
      },
      "requires": [
        "roundtrip"
      ],
      "expect_output": "expected_emit_roundtrip.yaml"
    }
  },
  "notes": "Default mode can emit these values plainly, while strict and y11safety must quote them.",
  "parse_profiles": {
    "baseline": {
      "modes": "all",
      "expect_node_graph": "expected_node_graph.json"
    }
  }
}
