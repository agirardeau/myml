{
  "summary": "A hash mid-scalar is accepted when not the first character and not preceded by a space",
  "tags": [
    "unquoted-string",
    "hash",
    "comment"
  ],
  "spec_refs": [
    "grammar.unquoted-strings",
    "grammar.comments"
  ],
  "notes": "The hash in `a#b` is interior and not preceded by a space, so it is part of the scalar rather than starting a comment.",
  "parse_profiles": {
    "baseline": {
      "modes": [
        "default",
        "y11safety"
      ],
      "expect_node_graph": "expected_node_graph.json"
    },
    "strict": {
      "modes": [
        "strict"
      ],
      "expect_error": {
        "code": "strict-mode-unquoted-string",
        "category": "mode_restriction",
        "line": 1,
        "column": 8
      }
    }
  },
  "emit_profiles": {
    "default": {
      "mode": "default",
      "expect_output": "expected_emit_default.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    }
  }
}
