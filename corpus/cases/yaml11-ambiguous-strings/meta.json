{
  "summary": "Quoted strings can stay valid while covering YAML 1.1-ambiguous spellings",
  "tags": [
    "string",
    "standard-mode",
    "strict",
    "emit"
  ],
  "spec_refs": [
    "optional.strict-mode",
    "optional.standard-mode",
    "serialization-defaults"
  ],
  "emit_profiles": {
    "standard": {
      "mode": "standard",
      "expect_output": "expected_emit_standard.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    },
    "roundtrip": {
      "mode": "standard",
      "options": {
        "roundtrip": true
      },
      "requires": [
        "roundtrip"
      ],
      "expect_output": "expected_emit_roundtrip.yaml"
    }
  },
  "notes": "Standard mode can emit these values plainly, while strict mode must quote them.",
  "parse_profiles": {
    "baseline": {
      "modes": "all",
      "expect_node_graph": "expected_node_graph.json"
    }
  }
}
