{
  "summary": "Standard mode treats sexagesimal-like values as strings",
  "tags": [
    "standard-mode",
    "sexagesimal",
    "mode"
  ],
  "spec_refs": [
    "optional.standard-mode"
  ],
  "notes": "The embedded colon is valid in standard mode because it is not the last character and not followed by a space.",
  "parse_profiles": {
    "standard": {
      "modes": [
        "standard"
      ],
      "expect_node_graph": "expected_node_graph.json"
    },
    "strict": {
      "modes": [
        "strict"
      ],
      "expect_error": {
        "code": "strict-mode-unquoted-string",
        "category": "mode_restriction",
        "line": 1,
        "column": 8
      }
    }
  },
  "emit_profiles": {
    "standard": {
      "mode": "standard",
      "expect_output": "expected_emit_standard.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    }
  }
}
