{
  "summary": "Comments and blank lines are ignored outside quoted or block scalars",
  "tags": [
    "comments",
    "empty-lines",
    "unquoted-string"
  ],
  "spec_refs": [
    "grammar.comments",
    "grammar.empty-lines",
    "grammar.unquoted-strings"
  ],
  "emit_profiles": {
    "standard": {
      "mode": "standard",
      "expect_output": "expected_emit_standard.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    },
    "roundtrip": {
      "mode": "standard",
      "options": {
        "roundtrip": true
      },
      "requires": [
        "roundtrip"
      ],
      "expect_output": "expected_emit_roundtrip.yaml"
    }
  },
  "notes": "Covers leading comments, blank lines, and trailing comments after a scalar.",
  "parse_profiles": {
    "baseline": {
      "modes": [
        "standard"
      ],
      "expect_node_graph": "expected_node_graph.json"
    },
    "strict": {
      "modes": [
        "strict"
      ],
      "expect_error": {
        "code": "strict-mode-unquoted-string",
        "category": "mode_restriction",
        "line": 2,
        "column": 7
      }
    }
  }
}
