{
  "summary": "Strict mode rejects unquoted string scalars",
  "tags": [
    "strict-mode",
    "string",
    "mode"
  ],
  "spec_refs": [
    "optional.strict-mode",
    "scalar-resolution.string"
  ],
  "notes": "The same document is valid in standard mode.",
  "parse_profiles": {
    "baseline": {
      "modes": [
        "standard"
      ],
      "expect_node_graph": "expected_node_graph.json"
    },
    "strict": {
      "modes": [
        "strict"
      ],
      "expect_error": {
        "code": "strict-mode-unquoted-string",
        "category": "mode_restriction",
        "line": 1,
        "column": 8
      }
    }
  },
  "emit_profiles": {
    "standard": {
      "mode": "standard",
      "expect_output": "expected_emit_standard.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    }
  }
}
