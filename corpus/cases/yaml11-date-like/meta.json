{
  "summary": "YAML 1.1 Safety Mode rejects date-like strings",
  "tags": [
    "y11safety",
    "datetime",
    "mode"
  ],
  "spec_refs": [
    "optional.yaml11-safety"
  ],
  "notes": "Uses an ISO 8601-style date literal.",
  "parse_profiles": {
    "default": {
      "modes": [
        "default"
      ],
      "expect_node_graph": "expected_node_graph.json"
    },
    "strict": {
      "modes": [
        "strict"
      ],
      "expect_error": {
        "code": "strict-mode-unquoted-string",
        "category": "mode_restriction",
        "line": 1,
        "column": 8
      }
    },
    "y11safety": {
      "modes": [
        "y11safety"
      ],
      "expect_error": {
        "code": "yaml11-safety-date-like",
        "category": "mode_restriction",
        "line": 1,
        "column": 8
      }
    }
  },
  "emit_profiles": {
    "default": {
      "mode": "default",
      "expect_output": "expected_emit_default.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    },
    "y11safety": {
      "mode": "y11safety",
      "expect_output": "expected_emit_y11safety.yaml"
    }
  }
}
