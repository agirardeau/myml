{
  "summary": "A colon mid-scalar is accepted when not the last character and not followed by a space",
  "tags": [
    "unquoted-string",
    "colon"
  ],
  "spec_refs": [
    "grammar.unquoted-strings"
  ],
  "notes": "The colon in `a:b` is interior and not followed by a space, so the scalar is valid.",
  "parse_profiles": {
    "baseline": {
      "modes": [
        "standard"
      ],
      "expect_node_graph": "expected_node_graph.json"
    },
    "strict": {
      "modes": [
        "strict"
      ],
      "expect_error": {
        "code": "strict-mode-unquoted-string",
        "category": "mode_restriction",
        "line": 1,
        "column": 8
      }
    }
  },
  "emit_profiles": {
    "standard": {
      "mode": "standard",
      "expect_output": "expected_emit_standard.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    }
  }
}
