{
  "summary": "A leading dash followed by a space is rejected in an unquoted scalar",
  "tags": [
    "unquoted-string",
    "dash",
    "lexical"
  ],
  "spec_refs": [
    "grammar.unquoted-strings"
  ],
  "notes": "A dash may start an unquoted scalar unless it is followed by a space character.",
  "parse_profiles": {
    "baseline": {
      "modes": [
        "standard"
      ],
      "expect_error": {
        "code": "invalid-string",
        "category": "lexical_error",
        "line": 1,
        "column": 8
      }
    },
    "strict": {
      "modes": [
        "strict"
      ],
      "expect_error": {
        "code": "strict-mode-unquoted-string",
        "category": "mode_restriction",
        "line": 1,
        "column": 8
      }
    }
  },
  "emit_profiles": {}
}
