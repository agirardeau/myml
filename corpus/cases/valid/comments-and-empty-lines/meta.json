{
  "summary": "Comments and blank lines are ignored outside quoted or block scalars",
  "tags": ["comments", "empty-lines", "unquoted-string"],
  "spec_refs": ["grammar.comments", "grammar.empty-lines", "grammar.unquoted-strings"],
  "modes": ["default"],
  "emit_profiles": {
    "default": "expected_emit_default.yaml",
    "strict": "expected_emit_strict.yaml",
    "roundtrip": "expected_emit_roundtrip.yaml",
    "roundtrip_edit_note": "expected_emit_roundtrip_edit_note.yaml"
  },
  "notes": "Covers leading comments, blank lines, and trailing comments after a scalar.",
  "roundtrip_edits": [
    {
      "path": ["note"],
      "value": "updated text",
      "emit_profile": "roundtrip_edit_note"
    }
  ]
}
