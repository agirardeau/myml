{
  "summary": "Literal and folded block scalar strings are accepted",
  "tags": [
    "strings",
    "block-scalar",
    "literal",
    "folded"
  ],
  "spec_refs": [
    "grammar.string-forms",
    "grammar.block-scalar-strings"
  ],
  "emit_profiles": {
    "default": {
      "mode": "default",
      "expect_output": "expected_emit_default.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    },
    "roundtrip": {
      "mode": "default",
      "options": {
        "roundtrip": true
      },
      "requires": [
        "roundtrip"
      ],
      "expect_output": "expected_emit_roundtrip.yaml"
    }
  },
  "notes": "Relies on default YAML clip behavior for both block scalar forms.",
  "parse_profiles": {
    "baseline": {
      "modes": "all",
      "expect_node_graph": "expected_node_graph.json"
    }
  }
}
