{
  "summary": "YAML 1.1 Safety Mode rejects sexagesimal-looking strings",
  "tags": [
    "y11safety",
    "sexagesimal",
    "mode"
  ],
  "spec_refs": [
    "optional.yaml11-safety"
  ],
  "notes": "This case also contains `:` and therefore would be invalid in default mode for a different reason.",
  "parse_profiles": {
    "default_strict": {
      "modes": [
        "default",
        "strict"
      ],
      "expect_error": {
        "code": "unquoted-colon",
        "category": "lexical_error",
        "line": 1,
        "column": 8
      }
    },
    "y11safety": {
      "modes": [
        "y11safety"
      ],
      "expect_error": {
        "code": "yaml11-safety-sexagesimal-like",
        "category": "mode_restriction",
        "line": 1,
        "column": 8
      }
    }
  },
  "emit_profiles": {}
}
