{
  "summary": "Dollar, plus, equals, semicolon, less-than, backslash, and tilde are accepted in unquoted scalars",
  "tags": [
    "unquoted-string"
  ],
  "spec_refs": [
    "grammar.unquoted-strings"
  ],
  "notes": "Each value exercises one character from the set permitted anywhere within an unquoted scalar.",
  "parse_profiles": {
    "baseline": {
      "modes": [
        "default",
        "y11safety"
      ],
      "expect_node_graph": "expected_node_graph.json"
    },
    "strict": {
      "modes": [
        "strict"
      ],
      "expect_error": {
        "code": "strict-mode-unquoted-string",
        "category": "mode_restriction",
        "line": 1,
        "column": 9
      }
    }
  },
  "emit_profiles": {
    "default": {
      "mode": "default",
      "expect_output": "expected_emit_default.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    }
  }
}
