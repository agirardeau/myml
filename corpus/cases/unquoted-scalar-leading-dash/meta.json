{
  "summary": "A leading dash followed by a non-space character is accepted as an unquoted scalar",
  "tags": [
    "unquoted-string",
    "dash"
  ],
  "spec_refs": [
    "grammar.unquoted-strings"
  ],
  "notes": "A dash is only forbidden as the first character when followed by a space. `-x` does not meet that condition.",
  "parse_profiles": {
    "baseline": {
      "modes": [
        "standard"
      ],
      "expect_node_graph": "expected_node_graph.json"
    },
    "strict": {
      "modes": [
        "strict"
      ],
      "expect_error": {
        "code": "strict-mode-unquoted-string",
        "category": "mode_restriction",
        "line": 1,
        "column": 8
      }
    }
  },
  "emit_profiles": {
    "standard": {
      "mode": "standard",
      "expect_output": "expected_emit_standard.yaml"
    },
    "strict": {
      "mode": "strict",
      "expect_output": "expected_emit_strict.yaml"
    }
  }
}
